# React Native/Expo declaram peer deps muito estritas. O resolvedor padrão do
# npm (npm 7+) falha com ERESOLVE em conjuntos de versões que o Expo já garante
# serem compatíveis. legacy-peer-deps faz o npm respeitar o package.json curado
# pelo `expo install`, evitando esses falsos conflitos.
legacy-peer-deps=true
